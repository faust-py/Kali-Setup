# ─────────────────────────────────────────────────────────────────────────────
# COLORS & FORMATTING
# ─────────────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING HELPERS
# ─────────────────────────────────────────────────────────────────────────────
log_info()    { echo -e "${CYAN}[*]${NC} $1"; }
log_success() { echo -e "${GREEN}[✔]${NC} $1"; }
log_warn()    { echo -e "${YELLOW}[!]${NC} $1"; }
log_error()   { echo -e "${RED}[✘]${NC} $1"; }
log_section() {
    echo ""
    echo -e "${BOLD}${BLUE}══════════════════════════════════════════${NC}"
    echo -e "${BOLD}${BLUE}  $1${NC}"
    echo -e "${BOLD}${BLUE}══════════════════════════════════════════${NC}"
}

# ─────────────────────────────────────────────────────────────────────────────
# TRACKING
# ─────────────────────────────────────────────────────────────────────────────
FAILED_PACKAGES=()
FAILED_GO_TOOLS=()

# ─────────────────────────────────────────────────────────────────────────────
# HELPER: safe apt install
# ─────────────────────────────────────────────────────────────────────────────
safe_apt_install() {
    local pkg="$1"
    if apt-get install -y "$pkg" &>/dev/null; then
        log_success "Installed: $pkg"
    else
        log_warn "Failed to install: $pkg (skipping)"
        FAILED_PACKAGES+=("$pkg")
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# HELPER: safe go install
# ─────────────────────────────────────────────────────────────────────────────
safe_go_install() {
    local pkg="$1"
    local name
    name=$(basename "$pkg" | cut -d@ -f1)
    if go install "$pkg" &>/dev/null; then
        log_success "Installed: $name"
    else
        log_warn "Failed: $name"
        FAILED_GO_TOOLS+=("$pkg")
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# INSTALL GO (called automatically if go is missing)
# ─────────────────────────────────────────────────────────────────────────────
install_go() {
    log_section "Installing Go"

    log_info "Installing Go via apt ..."
    if apt-get install -y golang &>/dev/null; then
        log_success "Go $(go version | awk '{print $3}') installed successfully"
    else
        log_error "Failed to install Go via apt."
        return 1
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# SYSTEM CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
configure_system() {
    log_section "System Configuration"

    # DNS
    log_info "Setting DNS to Cloudflare (1.1.1.1) ..."
    echo "nameserver 1.1.1.1" > /etc/resolv.conf
    echo "nameserver 8.8.8.8" >> /etc/resolv.conf
    log_success "DNS configured"

    # IP forwarding (persistent)
    log_info "Enabling IPv4 forwarding (persistent) ..."
    echo 1 > /proc/sys/net/ipv4/ip_forward  
    log_success "IP forwarding enabled"
}

# ─────────────────────────────────────────────────────────────────────────────
# REPOSITORIES
# ─────────────────────────────────────────────────────────────────────────────
add_repositories() {
    log_section "Adding Repositories"

    # Sublime Text
    log_info "Adding Sublime Text repo ..."
    wget -qO - https://download.sublimetext.com/sublimehq-pub.gpg \
        | gpg --dearmor \
        | tee /etc/apt/trusted.gpg.d/sublimehq-archive.gpg > /dev/null
    echo "deb https://download.sublimetext.com/ apt/stable/" \
        | tee /etc/apt/sources.list.d/sublime-text.list > /dev/null
    log_success "Sublime Text repo added"

    # Update package lists
    log_info "Updating package lists ..."
    apt-get update
    log_success "Package lists updated"
}

# ─────────────────────────────────────────────────────────────────────────────
# APT PACKAGES — grouped by category
# ─────────────────────────────────────────────────────────────────────────────
install_apt_packages() {

    # ── Recon & OSINT ──────────────────────────────────────────────────────
    log_section "Installing: Recon & OSINT"
    local recon_tools=(
        seclists          # wordlists
        maltego           # visual OSINT
        spiderfoot        # automated OSINT
        sublist3r         # subdomain enumeration
        subfinder         # fast subdomain discovery
        assetfinder       # subdomain & asset finder
        amass             # in-depth subdomain enumeration
        recon-ng          # web recon framework
    )
    for pkg in "${recon_tools[@]}"; do safe_apt_install "$pkg"; done

    # ── Web Application ────────────────────────────────────────────────────
    log_section "Installing: Web Application Tools"
    local web_tools=(
        gobuster          # directory/DNS brute-forcer
        ffuf              # fast fuzzer
        dirsearch         # web path scanner
        feroxbuster       # recursive content discovery
        nikto             # web server scanner
        zaproxy           # OWASP ZAP
        nuclei            # vulnerability scanner
        sqlmap            # SQL injection
        wpscan            # WordPress scanner
        httprobe          # HTTP/HTTPS probe
        beef-xss          # browser exploitation framework
        beef              # browser exploitation (alt pkg name)
    )
    for pkg in "${web_tools[@]}"; do safe_apt_install "$pkg"; done

    # ── Network & Sniffing ─────────────────────────────────────────────────
    log_section "Installing: Network & Sniffing"
    local network_tools=(
        nmap              # port scanner
        naabu             # fast port scanner
        ettercap-graphical
        ettercap-common
        bettercap         # network attack & monitoring
        responder         # LLMNR/NBT-NS poisoning
        netdiscover       # network scanner
        wireshark         # packet capture
    )
    for pkg in "${network_tools[@]}"; do safe_apt_install "$pkg"; done

    # ── Exploitation ───────────────────────────────────────────────────────
    log_section "Installing: Exploitation Frameworks"
    local exploit_tools=(
        armitage          # Metasploit GUI
        villain           # C2 framework
        crackmapexec      # SMB/AD swiss army knife
        impacket-scripts  # AD/Windows attack scripts
    )
    for pkg in "${exploit_tools[@]}"; do safe_apt_install "$pkg"; done

    # ── Password Attacks ───────────────────────────────────────────────────
    log_section "Installing: Password & Hash Tools"
    local password_tools=(
        cewl              # custom wordlist from URL
    )
    for pkg in "${password_tools[@]}"; do safe_apt_install "$pkg"; done

    # ── Post-Exploitation ──────────────────────────────────────────────────
    log_section "Installing: Post-Exploitation"
    local postex_tools=(
        adb               # Android debug bridge
        chisel            # TCP tunneling
        proxychains4      # proxy chains
        socat             # multipurpose relay
        mingw-w64         # Windows cross-compilation
    )
    for pkg in "${postex_tools[@]}"; do safe_apt_install "$pkg"; done

    # ── Wireless ───────────────────────────────────────────────────────────
    log_section "Installing: Wireless Tools"
    local wireless_tools=(
        airgeddon         # wireless attack framework
        wifiphisher       # phishing AP attacks
        hcxdumptool       # WiFi packet capture
        hcxtools          # hash conversion
        hostapd           # AP daemon
        reaver            # WPS brute force
        pixiewps          # offline WPS attack
        isc-dhcp-server   # DHCP server
        dkms
        bc
        linux-headers-$(uname -r)
        realtek-rtl8188eus-dkms
    )
    for pkg in "${wireless_tools[@]}"; do safe_apt_install "$pkg"; done

    # ── Utilities & UI ─────────────────────────────────────────────────────
    log_section "Installing: Utilities & UI"
    local utility_tools=(
        zenmap            # Nmap GUI
        terminator        # terminal emulator
        sublime-text      # text editor
        lsd               # modern ls
        kali-wallpapers-all
        libjsoncpp-dev
        curl
        wget
        git
        jq                # JSON processor
        tmux              # terminal multiplexer
        htop              # process monitor
        tree              # directory tree
    )
    for pkg in "${utility_tools[@]}"; do safe_apt_install "$pkg"; done
}

# ─────────────────────────────────────────────────────────────────────────────
# GO TOOLS
# ─────────────────────────────────────────────────────────────────────────────
install_go_tools() {
    log_section "Installing: Go Tools"

    if ! command -v go &>/dev/null; then
        log_warn "Go not found. Installing ..."
        install_go || return
    fi

    # Paths
    export GOPATH="${HOME}/go"
    export GOBIN="${HOME}/.local/bin"
    export PATH="${PATH}:${GOBIN}"

    # Create binary directory
    mkdir -p "$GOBIN"

    log_info "Go binaries will be installed to: $GOBIN"

    local go_tools=(
        # Recon & Discovery
        "github.com/projectdiscovery/katana/cmd/katana@latest"
        "github.com/projectdiscovery/httpx/cmd/httpx@latest"
        "github.com/projectdiscovery/dnsx/cmd/dnsx@latest"
        "github.com/projectdiscovery/naabu/v2/cmd/naabu@latest"

        # URL & Web
        "github.com/tomnomnom/waybackurls@latest"
        "github.com/lc/gau/v2/cmd/gau@latest"
        "github.com/hakluke/hakrawler@latest"

        # Utilities
        "github.com/tomnomnom/anew@latest"
        "github.com/tomnomnom/gf@latest"
        "github.com/tomnomnom/httprobe@latest"
        "github.com/tomnomnom/assetfinder@latest"
    )

    for tool in "${go_tools[@]}"; do
        safe_go_install "$tool"
    done

    # Persist PATH
    local shell_configs=(
        "$HOME/.bashrc"
        "$HOME/.zshrc"
        "$HOME/.profile"
    )

    for file in "${shell_configs[@]}"; do
        touch "$file"

        if ! grep -q 'export PATH="$PATH:$HOME/.local/bin"' "$file"; then
            echo '' >> "$file"
            echo '# Go / local user binaries' >> "$file"
            echo 'export PATH="$PATH:$HOME/.local/bin"' >> "$file"

            log_success "Updated PATH in $file"
        fi
    done

    # Apply immediately
    export PATH="$PATH:$HOME/.local/bin"

    log_success "Go tools installed successfully"
    log_info "You can now run tools like:"
    echo "  katana"
    echo "  httpx"
    echo "  naabu"
    echo "  gau"
}

# ─────────────────────────────────────────────────────────────────────────────
# POST-INSTALL TWEAKS
# ─────────────────────────────────────────────────────────────────────────────
post_install_tweaks() {
    log_section "Post-Install Tweaks"

    # Refresh font cache
    log_info "Refreshing font cache ..."
    fc-cache -fv &>/dev/null
    log_success "Font cache updated"

    # Set lsd as ls alias
    if command -v lsd &>/dev/null; then
        log_info "Setting lsd aliases ..."
        {
            echo "alias ls='lsd'"
            echo "alias ll='lsd -la'"
            echo "alias lt='lsd --tree'"
        } >> /root/.bashrc
        log_success "lsd aliases added to .bashrc"
    fi

    # Enable services
    log_info "Enabling useful services ..."
    systemctl enable ssh &>/dev/null && log_success "SSH enabled" || log_warn "SSH enable failed"
}

# ─────────────────────────────────────────────────────────────────────────────
# SUMMARY REPORT
# ─────────────────────────────────────────────────────────────────────────────
print_summary() {
    log_section "Installation Summary"

    if [ ${#FAILED_PACKAGES[@]} -eq 0 ] && [ ${#FAILED_GO_TOOLS[@]} -eq 0 ]; then
        log_success "All tools installed successfully!"
    else
        if [ ${#FAILED_PACKAGES[@]} -gt 0 ]; then
            log_warn "Failed APT packages (${#FAILED_PACKAGES[@]}):"
            for pkg in "${FAILED_PACKAGES[@]}"; do
                echo -e "  ${RED}✘${NC} $pkg"
            done
        fi
        if [ ${#FAILED_GO_TOOLS[@]} -gt 0 ]; then
            log_warn "Failed Go tools (${#FAILED_GO_TOOLS[@]}):"
            for tool in "${FAILED_GO_TOOLS[@]}"; do
                echo -e "  ${RED}✘${NC} $tool"
            done
        fi
    fi

    echo ""
    echo -e "${BOLD}${GREEN}════════════════════════════════════════${NC}"
    echo -e "${BOLD}${GREEN}  Setup complete! Happy hacking. 🎯${NC}"
    echo -e "${BOLD}${GREEN}════════════════════════════════════════${NC}"
    echo ""
    log_warn "Reboot recommended to apply all kernel/driver changes."
}

# ─────────────────────────────────────────────────────────────────────────────
# MAIN
# ─────────────────────────────────────────────────────────────────────────────
main() {
    clear
    echo -e "${CYAN}"
    cat << 'EOF'
 ██╗  ██╗ █████╗ ██╗     ██╗    ███████╗███████╗████████╗██╗   ██╗██████╗
 ██║ ██╔╝██╔══██╗██║     ██║    ██╔════╝██╔════╝╚══██╔══╝██║   ██║██╔══██╗
 █████╔╝ ███████║██║     ██║    ███████╗█████╗     ██║   ██║   ██║██████╔╝
 ██╔═██╗ ██╔══██║██║     ██║    ╚════██║██╔══╝     ██║   ██║   ██║██╔═══╝
 ██║  ██╗██║  ██║███████╗██║    ███████║███████╗   ██║   ╚██████╔╝██║
 ╚═╝  ╚═╝╚═╝  ╚═╝╚══════╝╚═╝    ╚══════╝╚══════╝   ╚═╝    ╚═════╝ ╚═╝
EOF
    echo -e "${NC}"

    configure_system
    add_repositories
    install_apt_packages
    install_go_tools
    post_install_tweaks
    print_summary
}

main "$@"
